# ─────────────────────────────────────────────────────────────────────────────
# Spirited Wines POS — environment variables
# Copy what you need into Vercel Project Settings → Environment Variables.
# Locally, the PHP API falls back to XAMPP defaults, so you usually only need
# NEXT_PUBLIC_API_URL in .env.local for the frontend.
# ─────────────────────────────────────────────────────────────────────────────

# ── Frontend (Next.js) ──
# Local dev (PHP built-in server):
#   NEXT_PUBLIC_API_URL=http://127.0.0.1:8080/api
# Production on Vercel (PHP runs in the SAME project → same origin, relative):
#   NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_API_URL=/api

# ── Backend (PHP API) — set these in Vercel for production ──
# Connection details come from your managed MySQL provider
# (Aiven / Railway / TiDB Cloud / Clever Cloud — NOT PlanetScale, which blocks
# the runtime table changes this app performs).
DB_HOST=your-mysql-host
DB_PORT=3306
DB_NAME=pos_project
DB_USER=your-db-user
DB_PASS=your-db-password
DB_CHARSET=utf8mb4

# Managed MySQL requires TLS — turn it on in production:
DB_SSL=1
# Optional: path to a CA bundle (.pem) if you want strict cert verification.
DB_SSL_CA=

# Auth token signing secret — generate a long random value, e.g.:
#   openssl rand -hex 32
TOKEN_SECRET=replace-with-a-long-random-secret
TOKEN_TTL_HOURS=168

# CORS allowlist. With the single-project (same-origin) setup you can leave this
# as "*". If you split frontend/backend onto different domains, set it to your
# frontend origin(s), comma-separated:
#   ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=*
